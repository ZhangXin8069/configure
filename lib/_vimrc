    \ 'Unknown'   : '?'
    \ }
nnoremap <silent> <Leader>t :NERDTreeToggle<CR>
nnoremap <silent> <Leader>e :NERDTreeFind<CR>

" ===== vim-visual-multi =====
let g:VM_maps = {}
let g:VM_maps['Find Under'] = '<C-n>'
let g:VM_maps['Find Subword Under'] = '<C-n>'

" ===== rainbow =====
let g:rainbow_active = 1

" ===== vim-startify =====
