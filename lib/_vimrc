" ===== Vim Configuration — Zero External Dependencies =====
" 自动补全由 vim 内置 ins-completion 提供，无需任何外部工具。

" --- Visual Experience ---
set number                " Show absolute line numbers
set relativenumber        " Also show relative line numbers (current line is 0)
set cursorline            " Highlight the current line
syntax on                 " Enable syntax highlighting
set showmode              " Show current mode at the bottom
set showcmd               " Show partially typed commands

" --- Filetype Detection (required for omni-completion) ---
filetype plugin on        " Enable filetype plugins → activates built-in omni-completion

" --- Indentation and Spaces ---
set tabstop=4             " Tab width set to 4 spaces
set shiftwidth=4          " Auto-indent width
set expandtab             " Convert tabs to spaces
set autoindent            " Auto-indent based on previous line
set smartindent           " Smart indent based on syntax

" --- Search Settings ---
set hlsearch              " Highlight all search results
set incsearch             " Incremental search as you type
set ignorecase            " Ignore case in searches
set smartcase             " Case-sensitive if uppercase is used

" --- Editing Behavior ---
set backspace=indent,eol,start  " Allow backspace over indent, end of line, start of line
set mouse=a               " Enable mouse support (click, scroll)
set hidden                " Allow switching buffers without saving

" --- File Handling ---
set nobackup              " Disable backup files
set noswapfile            " Disable swap files (safe on modern drives)
set encoding=utf-8        " Use UTF-8 encoding

" --- Status Bar ---
set laststatus=2          " Always show status bar
set ruler                 " Show cursor line and column in the bottom right

" ===== Built-in Completion (Zero External Dependencies) =====
" Tab 触发/导航补全 — vim 原生 ins-completion，无需任何外部工具

set completeopt=menu,menuone,preview,noselect,noinsert
set complete=.,w,b,u,t,i
set pumheight=10

function! s:check_back_space() abort
    let col = col('.') - 1
    return !col || getline('.')[col - 1] =~# '\s'
endfunction

" Tab: 触发关键字补全 / 在弹出菜单中向前选择
inoremap <silent><expr> <TAB>
    \ pumvisible() ? "\<C-n>" :
    \ <SID>check_back_space() ? "\<TAB>" :
    \ "\<C-n>"

" Shift+Tab: 在弹出菜单中向后选择
inoremap <expr> <S-TAB> pumvisible() ? "\<C-p>" : "\<C-p>"

" Ctrl+Space: 触发 omni-completion (文件类型感知: Python/C/HTML/CSS/JS...)
inoremap <C-Space> <C-x><C-o>

" Ctrl+F: 触发文件路径补全
inoremap <C-@> <C-x><C-f>

" ===== Command-line Completion ---
set wildmenu               " Enhanced command-line completion menu
set wildmode=longest:full,full
set wildignore+=*.o,*.obj,*.pyc,*.swp,*.class,*.so,*.dylib,*.exe

" ===== Performance ---
set lazyredraw              " Don't redraw during macro execution
set ttyfast                 " Fast terminal connection
set scrolloff=3             " Keep 3 lines visible above/below cursor
set sidescrolloff=5         " Keep 5 columns visible left/right of cursor
set updatetime=300          " CursorHold trigger interval (ms)
set synmaxcol=200           " Don't highlight syntax beyond column 200
set display+=lastline       " Show as much of last line as possible

" ===== Persistent Undo ---
if has('persistent_undo')
    set undofile
    set undodir=~/.vim/undodir
endif

" ===== File Search (built-in :find, no fzf needed) ---
set path+=**                " :find searches recursively
nnoremap <Leader>f :find *
nnoremap <Leader>F :vimgrep //g **/*<Left><Left><Left><Left><Left><Left><Left>

" ===== vim-plug Plugins =====
call plug#begin('~/.vim/plugged')

Plug 'morhetz/gruvbox'
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'
Plug 'luochen1990/rainbow'
Plug 'preservim/nerdtree'
Plug 'mhinz/vim-startify'
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-surround'
Plug 'mg979/vim-visual-multi'
Plug 'jiangmiao/auto-pairs'
Plug 'tpope/vim-repeat'
Plug 'tpope/vim-unimpaired'
Plug 'junegunn/vim-easy-align'
Plug 'tpope/vim-fugitive'
Plug 'airblade/vim-gitgutter'
Plug 'junegunn/gv.vim'
Plug 'godlygeek/tabular'
if !empty($TMUX)
    Plug 'christoomey/vim-tmux-navigator'
    Plug 'tmux-plugins/vim-tmux-focus-events'
endif

call plug#end()

" ===== Theme =====
if has('termguicolors') && ($COLORTERM == 'truecolor' || $COLORTERM == '24bit')
    set termguicolors
endif
let g:gruvbox_contrast_dark = 'medium'
let g:gruvbox_italic = 1
silent! colorscheme gruvbox
set background=dark

